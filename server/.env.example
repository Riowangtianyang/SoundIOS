# AI 个人记忆助手 - 环境变量配置示例
# 复制此文件为 .env 并填入你的密钥

# ============================================
# 腾讯云 STT（语音转文字）
# 获取地址：https://console.cloud.tencent.com/cam/capi
# ============================================
TENCENT_SECRET_ID=你的SecretId
TENCENT_SECRET_KEY=你的SecretKey
TENCENT_APP_ID=你的AppId

# ============================================
# MiniMax（LLM 对话）
# 获取地址：https://platform.minimax.chat/
# ============================================
MINIMAX_API_KEY=你的APIKey

# ============================================
# 数据库（可选，默认使用 SQLite）
# ============================================
DATABASE_URL=sqlite:///./ai_memory.db

# ============================================
# 服务器配置（可选）
# ============================================
HOST=0.0.0.0
PORT=8000
