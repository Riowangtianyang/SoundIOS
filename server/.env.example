# AI 个人记忆助手 - 环境变量配置示例
# 复制此文件为 .env 并填入你的密钥

# ============================================
# MiniMax（STT + LLM + TTS）
# 获取地址：https://platform.minimax.chat/
# ============================================
MINIMAX_API_KEY=你的APIKey

# ============================================
# Supabase 数据库
# 获取地址：https://supabase.com/dashboard
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ============================================
# 服务器配置（可选）
# ============================================
HOST=0.0.0.0
PORT=8000

# ===== 部署说明 =====
# 开发环境：运行 python main.py
# 外网访问：使用 ngrok http 8000